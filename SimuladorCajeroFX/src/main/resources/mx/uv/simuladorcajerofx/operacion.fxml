<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<VBox alignment="TOP_CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mx.uv.simuladorcajerofx.controladores.OperacionController">
   <children>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <ImageView fitWidth="150" preserveRatio="true">
               <image>
                  <Image url="@/imagenes/logo.png" />
               </image>
            </ImageView>
            <Label fx:id="lbl_titulo" styleClass="lbl-titulo" text="" />
         </children>
      </HBox>
      <VBox alignment="TOP_CENTER" spacing="10.0">
         <children>
            <HBox alignment="CENTER" spacing="5">
               <children>
                  <Label prefHeight="25.0" prefWidth="200" text="Introduce el importe:" />
                  <TextField fx:id="txt_importe" prefWidth="200.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button styleClass="btn-entrar" onAction="#actionGuardar" text="Guardar" />
                  <Button styleClass="btn-cancelar" onAction="#actionCancelar" text="Cancelar" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
